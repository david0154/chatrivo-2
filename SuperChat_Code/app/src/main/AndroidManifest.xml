<?xml version="1.0" encoding="utf-8"?>
<!--
  Chatrivo - AndroidManifest.xml
  Package: com.nexuzy.chatrivo
  App Name: Chatrivo
  Version: 4.2.0
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ═══════════════════════════ PERMISSIONS ═══════════════════════════ -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Storage (Android 9 and below) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <!-- Media (Android 13+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <!-- ═══════════════════════════ APPLICATION ════════════════════════════ -->
    <application
        android:name=".ChatrivoApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:largeHeap="true"
        android:requestLegacyExternalStorage="true"
        android:usesCleartextTraffic="true"
        tools:replace="android:label">

        <!-- AdMob -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="@string/admob_app_id" />

        <!-- Google Maps -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="@string/maps_api_key" />

        <!-- ──── ACTIVITIES ──── -->

        <!-- Splash -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/SplashTheme">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep link: join.chatrivo.nexuzy.com -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="@string/group_invite_host" />
            </intent-filter>

            <!-- Deep link: chat.chatrivo.nexuzy.com -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="@string/account_link" />
            </intent-filter>
        </activity>

        <!-- Setup Flow -->
        <activity android:name=".activities.setup.RegisterActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.setup.PhoneNumberActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.setup.VerifyPhoneActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.setup.RegisterInfoActivity"
            android:screenOrientation="portrait" android:exported="false" />

        <!-- Core Chat -->
        <activity android:name=".activities.MainActivity"
            android:screenOrientation="portrait" android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:launchMode="singleTask" />
        <activity android:name=".activities.NewChatActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.ForwardActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.UserDetailsActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.ContactDetailsActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.MediaGalleryActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.FullscreenActivity"
            android:exported="false" />
        <activity android:name=".activities.BackupChatActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.AcceptInviteLink"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.AccountLink"
            android:screenOrientation="portrait" android:exported="false" />

        <!-- Group -->
        <activity android:name=".activities.NewGroupActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.ShareGroupLinkActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.SelectContactNumbersActivity"
            android:screenOrientation="portrait" android:exported="false" />

        <!-- Status -->
        <activity android:name=".activities.MyStatusActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.ViewStatusActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.TextStatusActivity"
            android:screenOrientation="portrait" android:exported="false" />

        <!-- Profile -->
        <activity android:name=".activities.ProfilePhotoActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.ProfilePhotoDialog"
            android:screenOrientation="portrait" android:exported="false" />

        <!-- Security -->
        <activity android:name=".activities.LockscreenActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.ChatLockActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.SaveE2EActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.Enable2svActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.TwoStepVerificationActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".security.ScamProtectionSettingsActivity"
            android:label="Scam Protection" android:exported="false" />

        <!-- Settings -->
        <activity android:name=".activities.settings.SettingsActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.settings.NotificationSettingsActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.settings.PrivacySettingsActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.settings.StorageSettingsActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.settings.ChatsSettingsActivity"
            android:screenOrientation="portrait" android:exported="false" />

        <!-- Calling -->
        <activity android:name=".activities.calling.SingleCallActivity"
            android:exported="false"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:keepScreenOn="true" />
        <activity android:name=".activities.calling.IncomingCallActivity"
            android:exported="false"
            android:showOnLockScreen="true"
            android:turnScreenOn="true" />
        <activity android:name=".activities.calling.GroupCallActivity"
            android:exported="false" />
        <activity android:name=".activities.GroupCallViewActivity"
            android:exported="false" />
        <activity android:name=".activities.NewCallActivity"
            android:exported="false" />

        <!-- Misc -->
        <activity android:name=".activities.CameraActivity"
            android:exported="false" />
        <activity android:name=".activities.QrActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.QrScanActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.UpdateActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.MaintenanceActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.AccountDisableActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.LoggedOutActivity"
            android:screenOrientation="portrait" android:exported="false" />
        <activity android:name=".activities.AgreePrivacyPolicyActivity"
            android:screenOrientation="portrait" android:exported="false" />

        <!-- AI Chat -->
        <activity android:name=".ai.AIChatActivity"
            android:label="Chatrivo AI"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <!-- ──── SERVICES ──── -->
        <service android:name=".services.NetworkService"
            android:exported="false" />
        <service android:name=".services.CallService"
            android:exported="false"
            android:foregroundServiceType="microphone|camera" />
        <service android:name=".services.MessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- ──── RECEIVERS ──── -->
        <receiver android:name=".receivers.BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
        <receiver android:name=".receivers.NetworkChangeReceiver"
            android:exported="false" />

    </application>
</manifest>
